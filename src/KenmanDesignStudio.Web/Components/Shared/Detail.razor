<div style="@($"display:flex;justify-content:space-between;align-items:baseline;gap:1rem;padding:.7rem 0;{(Last ? "" : "border-bottom:1px solid var(--mud-palette-lines-default);")}")">
    <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary);text-transform:uppercase;letter-spacing:1px;">@Label</MudText>
    <MudText Typo="Typo.body2" Style="@($"font-weight:500;text-align:right;{(Accent ? "color:var(--va-brass-deep);font-family:'Cormorant Garamond',serif;font-size:1.2rem;" : "")}")">@Value</MudText>
</div>

@code {
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public bool Accent { get; set; }
    [Parameter] public bool Last { get; set; }
}
