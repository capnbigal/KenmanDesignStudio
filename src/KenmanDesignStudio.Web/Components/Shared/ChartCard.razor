<MudPaper Elevation="0" Class="pa-5" Style="height:100%;border:1px solid var(--mud-palette-lines-default);border-radius:6px;">
    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:1rem;">
        <div>
            <MudText Typo="Typo.overline" Style="color:var(--va-brass-deep);letter-spacing:2px;">@Eyebrow</MudText>
            <MudText Typo="Typo.h6" Style="font-weight:500;">@Title</MudText>
        </div>
        @HeaderRight
    </div>
    @ChildContent
</MudPaper>

@code {
    [Parameter] public string Eyebrow { get; set; } = "";
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? HeaderRight { get; set; }
}
