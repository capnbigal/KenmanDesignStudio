<div class="@(Center ? "text-center" : "")" style="margin-bottom:@Margin;">
    <div class="va-eyebrow" style="@(Center ? "justify-content:center;" : "")">@Eyebrow</div>
    <MudText Typo="Typo.h3" Class="mt-2" Style="@($"color:{TitleColor};")">@Title</MudText>
    @if (!string.IsNullOrEmpty(Subtitle))
    {
        <MudText Class="mt-2" Style="@($"max-width:{(Center ? "640px;margin:.5rem auto 0;" : "640px;")}color:var(--mud-palette-text-secondary);")">@Subtitle</MudText>
    }
</div>

@code {
    [Parameter] public string Eyebrow { get; set; } = "";
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public bool Center { get; set; }
    [Parameter] public string TitleColor { get; set; } = "var(--mud-palette-text-primary)";
    [Parameter] public string Margin { get; set; } = "2rem";
}
