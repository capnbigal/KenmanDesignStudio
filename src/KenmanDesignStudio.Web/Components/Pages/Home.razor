@page "/"
@inject ShowcaseService Showcase
@inject ImageResolver Resolver
@inject NavigationManager Nav

<PageTitle>Kenman Design Studio · Landscape Architecture & Development</PageTitle>

<!-- ===== HERO ===== -->
<section class="va-hero">
    @if (_heroImage is not null)
    {
        <div class="va-hero-bg" style="@($"background-image:url('{_heroImage}');")"></div>
    }
    <MudContainer MaxWidth="MaxWidth.Large" Class="va-hero-inner">
        <div style="max-width:760px;">
            <div class="va-eyebrow va-reveal va-d1" style="color:#C8A95B;">Landscape Architecture · Design · Development</div>
            <h1 class="va-hero-title va-reveal va-d2 mt-4">
                Living architecture for the world's most <span class="va-hero-accent">extraordinary</span> places.
            </h1>
            <p class="va-reveal va-d3" style="color:#D9D5CC;font-size:1.15rem;max-width:560px;margin-top:1.5rem;line-height:1.7;">
                From rooftop sky gardens crowning landmark towers to championship golf landscapes and
                private estate grounds — we design and deliver the grounds that define a place.
            </p>
            <div class="va-reveal va-d4 mt-8" style="display:flex;gap:1rem;flex-wrap:wrap;">
                <MudButton Variant="Variant.Filled" Size="Size.Large" Href="/portfolio"
                           Style="background:#C8A95B;color:#16302B;font-weight:600;"
                           EndIcon="@Icons.Material.Filled.ArrowForward">View the Portfolio</MudButton>
                <MudButton Variant="Variant.Outlined" Size="Size.Large" Href="/consultation"
                           Style="border-color:rgba(244,241,234,.4);color:#F4F1EA;">Request a Consultation</MudButton>
            </div>
        </div>
    </MudContainer>
    <div style="position:absolute;bottom:1.5rem;left:50%;transform:translateX(-50%);z-index:2;color:#C8A95B;opacity:.8;">
        <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowDown" />
    </div>
</section>

<!-- ===== STATS STRIP ===== -->
<section class="va-section-deep" style="border-top:1px solid rgba(200,169,91,.18);">
    <MudContainer MaxWidth="MaxWidth.Large" Class="py-8">
        <MudGrid>
            <StatItem Value="@($"{_stats.Projects}+")" Label="Projects Delivered" />
            <StatItem Value="@Format.Money(_stats.Value)" Label="Landscape Value Created" />
            <StatItem Value="@($"{_stats.Clients}")" Label="Prestige Clients" />
            <StatItem Value="@($"{_stats.Awards}")" Label="Design Awards" />
        </MudGrid>
    </MudContainer>
</section>

<!-- ===== DISCIPLINES ===== -->
<section class="va-section-stone py-16">
    <MudContainer MaxWidth="MaxWidth.Large">
        <SectionHeader Center="true" Eyebrow="Our Disciplines"
                       Title="Six worlds, one atelier"
                       Subtitle="A rare breadth of mastery — each discipline led by specialists, unified by a singular design philosophy." />
        <MudGrid Class="mt-4">
            @foreach (var cat in CategoryCatalog.All)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudPaper Elevation="0" Class="va-lift pa-6" Style="height:100%;background:#fff;border:1px solid #E2DED4;border-radius:6px;cursor:pointer;"
                              @onclick="@(() => Nav.NavigateTo($"/portfolio?category={(int)cat.Category}"))">
                        <div style="@($"width:46px;height:46px;border-radius:6px;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,{cat.GradientFrom},{cat.GradientTo});")">
                            <MudIcon Icon="@CategoryIcon(cat.Category)" Style="color:#C8A95B;" />
                        </div>
                        <MudText Typo="Typo.h5" Class="mt-4" Style="font-family:'Cormorant Garamond',serif;font-weight:600;">@cat.Name</MudText>
                        <MudText Typo="Typo.body2" Class="mt-2" Style="color:#5E6B64;">@cat.Blurb</MudText>
                        <MudText Class="mt-3" Style="color:#A8842F;font-size:.78rem;letter-spacing:1px;text-transform:uppercase;">Explore @cat.ShortName →</MudText>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    </MudContainer>
</section>

<!-- ===== FEATURED WORK ===== -->
<section class="py-16" style="background:var(--mud-palette-background);">
    <MudContainer MaxWidth="MaxWidth.Large">
        <div style="display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:1rem;">
            <SectionHeader Eyebrow="Selected Work" Title="Signature commissions" Margin="0" />
            <MudButton Variant="Variant.Text" Href="/portfolio" EndIcon="@Icons.Material.Filled.ArrowForward"
                       Style="color:var(--va-brass-deep);">View all projects</MudButton>
        </div>
        <MudGrid Class="mt-6">
            @for (var i = 0; i < _featured.Count; i++)
            {
                var p = _featured[i];
                var span = i == 0 ? 8 : 4;
                <MudItem xs="12" sm="6" md="@span">
                    <ProjectCard Project="p" Aspect="@(i == 0 ? "16/10" : "4/3")" />
                </MudItem>
            }
        </MudGrid>
    </MudContainer>
</section>

<!-- ===== TESTIMONIAL HIGHLIGHT ===== -->
@if (_testimonial is not null)
{
    <section class="va-section-deep py-16">
        <MudContainer MaxWidth="MaxWidth.Medium" Class="text-center">
            <MudIcon Icon="@Icons.Material.Filled.FormatQuote" Style="color:#C8A95B;font-size:3rem;" />
            <MudText Typo="Typo.h4" Class="mt-2" Style="font-family:'Cormorant Garamond',serif;font-style:italic;font-weight:500;color:#F4F1EA;line-height:1.4;">
                “@_testimonial.Quote”
            </MudText>
            <MudText Class="mt-6" Style="color:#C8A95B;letter-spacing:1px;">@_testimonial.AuthorName</MudText>
            <MudText Typo="Typo.body2" Style="color:#AEB8B1;">@_testimonial.AuthorTitle, @_testimonial.Company</MudText>
        </MudContainer>
    </section>
}

<!-- ===== CTA ===== -->
<section class="va-section-stone py-16">
    <MudContainer MaxWidth="MaxWidth.Medium" Class="text-center">
        <SectionHeader Center="true" Eyebrow="Begin a Conversation"
                       Title="Let's design something enduring"
                       Subtitle="Share your vision and our principals will be in touch to arrange a private consultation." />
        <MudButton Variant="Variant.Filled" Size="Size.Large" Href="/consultation"
                   Style="background:#16302B;color:#F4F1EA;" EndIcon="@Icons.Material.Filled.ArrowForward">Request a Consultation</MudButton>
    </MudContainer>
</section>

@code {
    private List<Project> _featured = new();
    private Testimonial? _testimonial;
    private (int Projects, int Clients, decimal Value, int Awards) _stats;
    private string? _heroImage;

    protected override async Task OnInitializedAsync()
    {
        _featured = await Showcase.GetFeaturedAsync(5);
        _stats = await Showcase.GetStatsAsync();
        var testimonials = await Showcase.GetTestimonialsAsync(featuredOnly: true);
        _testimonial = testimonials.FirstOrDefault();

        var hero = _featured.FirstOrDefault()?.PrimaryImage?.Path;
        if (hero is not null) _heroImage = Resolver.Resolve(hero);
    }

    private static string CategoryIcon(ProjectCategory c) => c switch
    {
        ProjectCategory.RooftopSkyGarden => Icons.Material.Filled.Apartment,
        ProjectCategory.AirportTransit => Icons.Material.Filled.Flight,
        ProjectCategory.LuxuryResort => Icons.Material.Filled.Pool,
        ProjectCategory.PrivateEstate => Icons.Material.Filled.Villa,
        ProjectCategory.GolfCountryClub => Icons.Material.Filled.GolfCourse,
        ProjectCategory.CorporateCampus => Icons.Material.Filled.Business,
        _ => Icons.Material.Filled.Park,
    };
}
