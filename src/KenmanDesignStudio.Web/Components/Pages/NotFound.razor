@page "/not-found"

<PageTitle>Not Found · Kenman Design Studio</PageTitle>

<div class="va-section-deep" style="min-height:80vh;display:flex;align-items:center;">
    <MudContainer MaxWidth="MaxWidth.Small" Class="text-center">
        <div class="va-eyebrow" style="justify-content:center;">Error 404</div>
        <MudText Typo="Typo.h2" Class="mt-3" Style="color:#F4F1EA;">This path has not yet been landscaped.</MudText>
        <MudText Class="mt-3" Style="color:#AEB8B1;">The page you are looking for could not be found.</MudText>
        <MudButton Class="mt-6" Variant="Variant.Outlined" Href="/"
                   Style="border-color:rgba(200,169,91,.6);color:#C8A95B;">Return Home</MudButton>
    </MudContainer>
</div>
