# Copy to `.env` in /opt/kenmandesignstudio on the droplet, fill in, then `chmod 600 .env`.
# NEVER COMMIT THE .env FILE.

# --- SQL Server ---------------------------------------------------------------
# MUST be the SAME value as the AWBlazor stack's SA_PASSWORD — KDS connects to
# the existing awblazor-sqlserver container with the sa account.
SA_PASSWORD=USE_THE_SAME_PASSWORD_AS_AWBLAZOR

# --- App image tag (optional) ------------------------------------------------
# GHCR tag to pull. Defaults to "latest". Pin to a <short-sha> for rollbacks.
APP_TAG=latest
