# Copy to `.env` in this folder on the droplet, fill in, then `chmod 600 .env`.
# NEVER COMMIT THE .env FILE.

# --- Dashboard web UI login token --------------------------------------------
# You'll paste this once to log into the dashboard. Generate a strong value, e.g.:
#   openssl rand -base64 32
DASHBOARD_TOKEN=CHANGE_ME_long_random_token

# --- OTLP ingest API key ------------------------------------------------------
# Apps must send this as the x-otlp-api-key header. Use the SAME value here and in
# each app's .env (OTLP_API_KEY). Generate, e.g.:  openssl rand -base64 32
OTLP_API_KEY=CHANGE_ME_long_random_key
